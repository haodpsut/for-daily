# ===========================================
# Gia Phả Đỗ Phúc Tộc v2 — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.

# --- Site ---
SITE_NAME="Đỗ Phúc Tộc"
SITE_URL="http://localhost:3000"

# --- Database (Postgres) ---
# Local dev (via docker-compose): postgres://postgres:postgres@localhost:5432/giapha
# Neon (production): postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
DATABASE_URL="postgres://postgres:postgres@localhost:5432/giapha"

# --- Auth (S2 — chưa dùng ở S1) ---
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# --- File Storage ---
# Local dev: relative path
# Production (Vercel): leave empty + use Cloudflare R2 (configure below)
STORAGE_LOCAL_PATH="../storage"

# Cloudflare R2 (S2/S7 — chưa dùng ở S1)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="giapha-media"
# R2_PUBLIC_URL=""

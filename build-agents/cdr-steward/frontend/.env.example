# cdr-steward backend (PLO/Course/CLO/render). Production set ở Vercel dashboard.
# Dev: để trống → Vite proxy /api → localhost:8000
VITE_API_URL=

# kdcl-steward backend (đo CĐR thực tế từ điểm SV). Separate Render service.
# Production: VITE_KDCL_API_URL=https://kdcl-steward-api.onrender.com/api
# Dev: VITE_KDCL_API_URL=http://localhost:8001/api
# Để trống → fallback sang VITE_API_URL (chỉ dùng khi dev cdr-only, đo CĐR sẽ lỗi)
VITE_KDCL_API_URL=

# Share DB với cdr-steward để đọc Program/Course/CLO/PLO/PI/User.
# Local dev: trỏ vào file SQLite của cdr-steward.
DATABASE_URL=sqlite:///../cdr-steward/backend/cdr_steward.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost/cdr_steward

# Same JWT_SECRET so cdr-steward và kdcl-steward chấp nhận cùng token
JWT_SECRET=dev-secret-CHANGE-IN-PROD-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRE_DAYS=30

UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
TEMPLATE_DIR=../templates

LOG_LEVEL=INFO

# Copy to .env and fill in

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Database (Docker Compose default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quality_os

# Paths (relative to project root)
ISO_SOURCE=../de-an-thanh-lap-cong-ty/university/iso
CONGVAN_SOURCE=../de-an-thanh-lap-cong-ty/university/congvan
CRITERIA_MD_SOURCE=../kiem-dinh-chat-luong/PHAN-TICH-TONG-THE.md

# Sampling
SAMPLE_DOCS_PER_DEPT=10
SAMPLE_SEED=42

# Model choices
CLAUDE_MODEL_PRIMARY=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini

# Logging
LOG_LEVEL=INFO

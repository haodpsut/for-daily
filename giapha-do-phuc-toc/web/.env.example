# -----------------------------------------------------------------------------
# GIA PHẢ ĐỖ PHÚC TỘC - MẪU BIẾN MÔI TRƯỜNG (ENVIRONMENT VARIABLES)
# -----------------------------------------------------------------------------
# Hướng dẫn:
# 1. Chép (copy) file này thành ".env.local"
# 2. Điền các giá trị thực tế tương ứng với dự án Supabase của dòng họ

# Tên + tagline hiển thị trên web
SITE_NAME="Đỗ Phúc Tộc"
SITE_TAGLINE="Gia phả dòng họ"

# URL của project Supabase (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Khóa Public (Settings > API > Project API keys > anon / public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-anon-or-public-key"

# Reference: https://github.com/homielab/giapha-os (upstream MIT)
